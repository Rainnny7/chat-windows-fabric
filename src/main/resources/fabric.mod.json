{
	"schemaVersion": 1,
	"id": "chat-utilities",
	"version": "${version}",
	"name": "Chat Utilities",
	"description": "Filter chat into extra panes that you can drag and resize (/chatwindow). Patterns match as plain text; begin with regex: for Java regex.",
	"authors": [
		"Braydon (Rainnny)"
	],
	"contact": {
		"homepage": "https://rainnny.club",
		"sources": "https://github.com/Rainnny7/chat-windows"
	},
	"license": "CC0-1.0",
	"environment": "client",
	"entrypoints": {
		"client": [
			"me.braydon.chatutilities.ChatUtilitiesModClient"
		]
	},
	"accessWidener": "chat-utilities.accesswidener",
	"mixins": [
		{
			"config": "chat-utilities.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}